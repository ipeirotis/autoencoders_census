# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
env/
ENV/

# The Python `lib/` rule above is greedy (matches at any depth) and was
# silently swallowing the SPA's `frontend/client/lib/` directory, which holds
# the shadcn/ui `cn` helper imported by every UI component. Re-include it.
!frontend/client/lib/
!frontend/client/lib/**

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend/dist/
frontend/.next/
frontend/out/

# Data files
*.csv
*.h5
*.pkl
*.pth
*.ckpt


# OS
.DS_Store
Thumbs.db

# Model checkpoints
backend/data/models/
backend/data/checkpoints/
cache/

# --- Secrets & Keys 
service-account.json
*.json
!package.json
!tsconfig.json
!cors.json
!.cloud-config.json
!.claude/settings.json

# Cloud -- never commit plaintext credentials
credentials.json
credentials_clean.json
/tmp/

